FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    git \
    curl \
    jq \
    sudo \
    zsh \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
ARG HOST_UID=1000
ARG HOST_GID=1000
RUN userdel -r ubuntu 2>/dev/null || true && \
    groupadd -f -g $HOST_GID agent && \
    useradd -m -u $HOST_UID -g $HOST_GID -s /bin/zsh agent && \
    echo "agent ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER agent
WORKDIR /home/agent

# Install Claude Code as agent user
RUN curl -fsSL https://claude.ai/install.sh | bash
ENV PATH="/home/agent/.local/bin:$PATH"

# Skip first-run onboarding, trust dialog, and bypass permissions confirmation
RUN echo '{"hasCompletedOnboarding":true,"bypassPermissionsModeAccepted":true,"projects":{"/home/agent":{"hasTrustDialogAccepted":true}}}' > /home/agent/.claude.json

CMD ["zsh"]
