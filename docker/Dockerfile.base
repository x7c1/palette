FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    git \
    curl \
    jq \
    sudo \
    xxd \
    zsh \
    && rm -rf /var/lib/apt/lists/*

# Optional custom CA certs staged by scripts/build-images.sh
COPY .palette-build-certs/ /tmp/palette-build-certs/
RUN set -eu; \
    certs="$(find /tmp/palette-build-certs -type f \( -name '*.crt' -o -name '*.pem' \) 2>/dev/null || true)"; \
    if [ -n "$certs" ]; then \
      mkdir -p /usr/local/share/ca-certificates/custom; \
      for cert in $certs; do \
        name="$(basename "$cert")"; \
        name="${name%.*}.crt"; \
        cp "$cert" "/usr/local/share/ca-certificates/custom/$name"; \
      done; \
      update-ca-certificates; \
    fi

# Create non-root user
ARG HOST_UID=1000
ARG HOST_GID=1000
RUN userdel -r ubuntu 2>/dev/null || true && \
    groupadd -f -g $HOST_GID agent && \
    useradd -m -u $HOST_UID -g $HOST_GID -s /bin/zsh agent && \
    echo "agent ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER agent
WORKDIR /home/agent

# Install Claude Code as agent user (fail-fast).
RUN curl -fsSL https://claude.ai/install.sh | bash && \
    test -x /home/agent/.local/bin/claude
ENV PATH="/home/agent/.local/bin:$PATH"

# Pre-create directories so named volumes inherit agent ownership
RUN mkdir -p /home/agent/.claude/projects /home/agent/workspace

# Skip first-run onboarding, trust dialog, and bypass permissions confirmation.
RUN echo '{"hasCompletedOnboarding":true,"bypassPermissionsModeAccepted":true,"projects":{"/home/agent":{"hasTrustDialogAccepted":true},"/home/agent/workspace":{"hasTrustDialogAccepted":true}}}' > /home/agent/.claude.json

CMD ["zsh"]
