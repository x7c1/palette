{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(cp *)",
      "Bash(curl *)",
      "Bash(echo)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(mkdir -p *)",
      "Bash(xxd *)",
      "Bash(mv *)",
      "Bash(pwd)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git clone *)",
      "Bash(git commit *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git push *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Read(/home/agent/**)",
      "Edit(/home/agent/**)",
      "Write(/home/agent/**)",
      "Glob(/home/agent/**)",
      "Grep(/home/agent/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/guard-cd-chain.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H 'Content-Type: application/json' -d @- '{{PALETTE_SESSION_START_URL}}' || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H 'Content-Type: application/json' -d @- '{{PALETTE_STOP_URL}}' || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H 'Content-Type: application/json' -d @- '{{PALETTE_NOTIFICATION_URL}}' || true"
          }
        ]
      }
    ]
  }
}
