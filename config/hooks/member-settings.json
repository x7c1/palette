{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cd *)",
      "Bash(echo)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(pwd)",
      "Bash(git checkout *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "{{PALETTE_STOP_URL}}"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "http",
            "url": "{{PALETTE_NOTIFICATION_URL}}"
          }
        ]
      }
    ]
  }
}
