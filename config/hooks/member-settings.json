{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "{{PALETTE_STOP_URL}}"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "http",
            "url": "{{PALETTE_NOTIFICATION_URL}}"
          }
        ]
      }
    ]
  }
}
