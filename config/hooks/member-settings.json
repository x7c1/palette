{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://host.docker.internal:7100/hooks/stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "http",
            "url": "http://host.docker.internal:7100/hooks/notification"
          }
        ]
      }
    ]
  }
}
